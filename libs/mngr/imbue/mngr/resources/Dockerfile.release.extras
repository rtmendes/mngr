# This file is appended to Dockerfile (with the CMD line stripped) to
# produce Dockerfile.release. See justfile's _generate-release-dockerfile
# recipe. Keeps the two Dockerfiles in sync while letting the release
# image add Docker-in-Docker plumbing on top of the regular one.

# ---- Extra apt packages for Docker-in-Docker ----
RUN apt-get update && apt-get install -y --no-install-recommends \
    iproute2 \
    iptables \
    && rm -rf /var/lib/apt/lists/*

# ---- Docker-in-Docker (static binaries) ----
RUN curl -fsSL https://download.docker.com/linux/static/stable/x86_64/docker-27.5.1.tgz \
    | tar xz -C /usr/local/bin --strip-components=1

# Modern runc for reliable networking under gVisor
RUN rm -f /usr/local/bin/runc \
    && wget -q https://github.com/opencontainers/runc/releases/download/v1.3.0/runc.amd64 \
    && chmod +x runc.amd64 \
    && mv runc.amd64 /usr/local/bin/runc

# gVisor doesn't support nftables (https://github.com/google/gvisor/issues/10510)
RUN update-alternatives --set iptables /usr/sbin/iptables-legacy \
    && update-alternatives --set ip6tables /usr/sbin/ip6tables-legacy

# ---- Playwright (chromium + deps) baked in for minds release tests ----
# Bake-in (not sandbox_init_cmd) so the install only happens at image build
# time; otherwise every sandbox would re-download ~300MB.
#
# Pin PLAYWRIGHT_BROWSERS_PATH to an absolute location so tests that
# isolate $HOME (e.g. via the autouse isolate_home fixture in mngr's
# conftest) still find the baked-in chromium. The default lookup path
# is $HOME/.cache/ms-playwright, which points at the pytest tmp dir
# once isolate_home kicks in, where nothing is installed.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/ms-playwright
RUN uv run --with playwright python -m playwright install --with-deps chromium

# ---- minds_workspace_server frontend build ----
# The release e2e tests (apps/minds_workspace_server/imbue/minds_workspace_server/test_e2e.py)
# load the workspace-server UI in chromium and assert on rendered content.
# Without a built frontend, server.py serves an "Frontend not built" fallback
# page, so every locator check fails. Install node and run the build so
# apps/minds_workspace_server/imbue/minds_workspace_server/static/index.html
# is present. We use npm (not pnpm) to honour the committed package-lock.json
# and match the project's documented workflow (README, server.py fallback
# page, server_test.py assertion).
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*
RUN cd /code/mngr/apps/minds_workspace_server/frontend && \
    npm ci && \
    npm run build

# ---- Docker daemon startup script ----
# dockerd itself is started by the _ensure_dockerd_for_release pytest
# session fixture (libs/mngr/imbue/mngr/conftest.py), so we only need
# the start script on the image. No BASH_ENV indirection -- that used
# to trigger start-dockerd.sh per bash subshell and serialized tests.
COPY libs/mngr/imbue/mngr/resources/start-dockerd.sh /start-dockerd.sh
RUN chmod +x /start-dockerd.sh

# Run idly forever while being responsive to SIGTERM.
# PID 1 must explicitly install signal handlers in order to respect signals.
# Start dockerd as part of the sandbox launch.
CMD ["sh", "-c", "/start-dockerd.sh && trap 'exit 0' TERM; tail -f /dev/null & wait"]
